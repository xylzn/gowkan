---
import Button from './Button.astro';
import { SITE_CONFIG } from '../data/site-config';
---

<!-- Contact Section -->
<div id="contact-form-section" class="mb-32 px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start max-w-6xl mx-auto">
        <!-- Left: Contact Info -->
        <div class="lg:col-span-5 space-y-12 reveal">
            <div>
                <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-[#6366f1]/30 bg-[#6366f1]/10 text-[#6366f1] text-[10px] font-black uppercase tracking-widest">
                    Hubungi Kami
                </div>
                <h2 class="text-4xl md:text-5xl font-black mb-8 leading-tight tracking-tight">Mulai Project <span class="text-[#6366f1] italic">Masa Depan</span> Digital Anda Sekarang.</h2>
                <p class="text-white/40 text-lg leading-relaxed font-medium">
                    Tim ahli kami siap membantu mentransformasi bisnis Anda ke level berikutnya dengan solusi digital yang tepat guna.
                </p>
            </div>

            <div class="space-y-8">
                <!-- Alamat -->
                <div class="flex items-start gap-6 group">
                    <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center text-[#6366f1] group-hover:bg-[#6366f1] group-hover:text-white transition-all duration-500 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-sm font-black text-white/40 uppercase tracking-widest mb-1">Alamat Kantor</h4>
                        <p class="text-xl font-bold">{SITE_CONFIG.contact.address}</p>
                        <p class="text-white/40 text-sm font-medium mt-1">{SITE_CONFIG.contact.location}</p>
                    </div>
                </div>

                <!-- WhatsApp -->
                <div class="flex items-start gap-6 group">
                    <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center text-green-500 group-hover:bg-green-500 group-hover:text-white transition-all duration-500 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.659 1.437 5.634 1.437h.005c6.558 0 11.894-5.335 11.897-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-sm font-black text-white/40 uppercase tracking-widest mb-1">Kontak Cepat</h4>
                        <p class="text-xl font-bold">{SITE_CONFIG.contact.phone}</p>
                        <p class="text-white/40 text-sm font-medium mt-1">WhatsApp Terintegrasi</p>
                    </div>
                </div>

                <!-- Instagram -->
                <div class="flex items-start gap-6 group">
                    <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center text-pink-500 group-hover:bg-pink-500 group-hover:text-white transition-all duration-500 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </div>
                    <div>
                        <h4 class="text-sm font-black text-white/40 uppercase tracking-widest mb-1">Media Sosial</h4>
                        <p class="text-xl font-bold">{SITE_CONFIG.social.instagram}</p>
                        <p class="text-white/40 text-sm font-medium mt-1">Update Portofolio Terbaru</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-7 reveal">
            <div class="glass-card p-10 md:p-14 rounded-[4rem] border border-white/10 shadow-2xl relative overflow-hidden group">
                <!-- Background Decoration -->
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-[#6366f1]/10 blur-[100px] rounded-full group-hover:bg-[#6366f1]/20 transition-all duration-700"></div>
                
                <form id="gowkan-contact-form" class="relative z-10 space-y-10">
                    <div class="space-y-4">
                        <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 ml-4">Nama Perusahaan / Bisnis</label>
                        <div class="relative">
                            <input type="text" id="company-name" required placeholder="Contoh: Bengkel Maju Jaya" class="glass-input w-full focus:ring-2 focus:ring-[#6366f1]/20 pl-16">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 absolute left-6 top-1/2 -translate-y-1/2 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-7h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 ml-4">Email Aktif</label>
                        <div class="relative">
                            <input type="email" id="company-email" required placeholder="contoh@email.com" class="glass-input w-full focus:ring-2 focus:ring-[#6366f1]/20 pl-16">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 absolute left-6 top-1/2 -translate-y-1/2 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div class="space-y-4">
                            <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 ml-4">Sektor Usaha</label>
                            <div class="relative">
                                <select id="business-sector" required class="glass-input w-full appearance-none bg-[#0f172a]/50 pl-16">
                                    <option value="" disabled selected>Pilih Sektor Usaha</option>
                                    <option value="Law Firm">Law Firm / Hukum</option>
                                    <option value="Home Services">Home Services (AC/Renovasi)</option>
                                    <option value="Corporate">Corporate / Perusahaan</option>
                                    <option value="E-Commerce">E-Commerce / Toko Online</option>
                                    <option value="Restaurant">Restaurant / Kuliner</option>
                                    <option value="Photography">Photography / Kreatif</option>
                                    <option value="Medical">Medical / Kesehatan</option>
                                    <option value="Real Estate">Real Estate / Properti</option>
                                    <option value="Education">Education / Pendidikan</option>
                                    <option value="Lainnya">Lainnya</option>
                                </select>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 absolute left-6 top-1/2 -translate-y-1/2 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/40 ml-4">Pilih Paket Investasi</label>
                            <div class="relative">
                                <select id="selected-package" required class="glass-input w-full appearance-none bg-[#0f172a]/50 pl-16">
                                    <option value="" disabled selected>Pilih Paket</option>
                                    <option value="GOW-KILAT (Rp 1.500.000)">GOW-KILAT (Rp 1.500.000)</option>
                                    <option value="GOW-BRANDING (Rp 2.500.000)">GOW-BRANDING (Rp 2.500.000)</option>
                                    <option value="GOW-EXPERT (Rp 3.800.000)">GOW-EXPERT (Rp 3.800.000)</option>
                                </select>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 absolute left-6 top-1/2 -translate-y-1/2 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div class="pt-6">
                        <Button type="submit" variant="primary" class="w-full py-5 rounded-[2.5rem] text-lg group/btn">
                            KIRIM KE WHATSAPP 
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover/btn:translate-x-2 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                        </Button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    import { SITE_CONFIG } from '../data/site-config';

    const contactForm = document.getElementById('gowkan-contact-form');
    if (contactForm) {
        contactForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const companyName = (document.getElementById('company-name') as HTMLInputElement).value;
            const companyEmail = (document.getElementById('company-email') as HTMLInputElement).value;
            const businessSector = (document.getElementById('business-sector') as HTMLSelectElement).value;
            const selectedPackage = (document.getElementById('selected-package') as HTMLSelectElement).value;

            const whatsappNumber = SITE_CONFIG.contact.whatsapp;
            
            const message = `Halo Admin ${SITE_CONFIG.name}, saya dari perusahaan *${companyName}*.\n\n` +
                            `Saya ingin membuat website dengan rincian sebagai berikut:\n` +
                            `• *Email:* ${companyEmail}\n` +
                            `• *Sektor Usaha:* ${businessSector}\n` +
                            `• *Paket Investasi:* ${selectedPackage}\n\n` +
                            `Mohon informasinya lebih lanjut. Terima kasih!`;
            
            const encodedMessage = encodeURIComponent(message);
            const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
            
            window.open(whatsappUrl, '_blank');
        });
    }
</script>
