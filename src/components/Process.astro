---
---

<!-- Process Section -->
<section id="process" class="py-24 px-6 relative overflow-hidden bg-white/[0.01]">
    <div class="container mx-auto max-w-6xl reveal">
        <div class="text-center mb-20">
            <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-[#6366f1]/30 bg-[#6366f1]/10 text-[#6366f1] text-[10px] font-bold uppercase tracking-widest">
                Langkah Kerja
            </div>
            <h2 class="text-4xl md:text-5xl font-black mb-6 tracking-tight">3 Langkah Mudah Memiliki <span class="text-[#6366f1]">Website Profesional</span></h2>
            <p class="text-white/40 font-medium">Proses pengerjaan yang transparan dan tanpa ribet.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative">
            <!-- Connecting Line (Desktop) -->
            <div class="hidden md:block absolute top-1/4 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-white/10 to-transparent -z-10"></div>
            
            <!-- Step 1 -->
            <div class="text-center group">
                <div class="w-20 h-20 bg-dark border-2 border-white/10 rounded-full flex items-center justify-center text-3xl font-black text-white/20 mx-auto mb-8 group-hover:border-[#6366f1] group-hover:text-[#6366f1] transition-all duration-500 relative">
                    1
                    <div class="absolute inset-0 bg-[#6366f1]/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <h4 class="text-xl font-bold mb-4">Konsultasi & Pilih Paket</h4>
                <p class="text-white/40 text-sm leading-relaxed">Diskusikan kebutuhan bisnis Anda bersama tim ahli kami melalui WhatsApp.</p>
            </div>
            
            <!-- Step 2 -->
            <div class="text-center group">
                <div class="w-20 h-20 bg-dark border-2 border-white/10 rounded-full flex items-center justify-center text-3xl font-black text-white/20 mx-auto mb-8 group-hover:border-[#a855f7] group-hover:text-[#a855f7] transition-all duration-500 relative">
                    2
                    <div class="absolute inset-0 bg-[#a855f7]/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <h4 class="text-xl font-bold mb-4">Kirim Data Bisnis</h4>
                <p class="text-white/40 text-sm leading-relaxed">Cukup kirimkan foto dan penjelasan jasa/produk Anda melalui WhatsApp.</p>
            </div>
            
            <!-- Step 3 -->
            <div class="text-center group">
                <div class="w-20 h-20 bg-dark border-2 border-white/10 rounded-full flex items-center justify-center text-3xl font-black text-white/20 mx-auto mb-8 group-hover:border-[#ec4899] group-hover:text-[#ec4899] transition-all duration-500 relative">
                    3
                    <div class="absolute inset-0 bg-[#ec4899]/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
                <h4 class="text-xl font-bold mb-4">Website Online!</h4>
                <p class="text-white/40 text-sm leading-relaxed">Dalam hitungan hari, website Anda siap digunakan untuk jualan.</p>
            </div>
        </div>

        <div class="mt-24 glass-card p-12 rounded-[3rem] border border-white/10 max-w-4xl mx-auto">
            <div class="flex flex-col md:flex-row gap-12 items-center">
                <div class="shrink-0">
                    <div class="w-16 h-16 bg-[#6366f1]/10 rounded-2xl flex items-center justify-center text-[#6366f1]">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                </div>
                <div>
                    <h4 class="text-xl font-bold mb-2 text-white">Apakah saya bisa mengubah isi website nanti?</h4>
                    <p class="text-white/40 leading-relaxed font-medium">Tentu. Sistem kami sangat simpel, atau Anda bisa meminta bantuan kami untuk update ringan kapan saja.</p>
                </div>
            </div>
        </div>
    </div>
</section>
