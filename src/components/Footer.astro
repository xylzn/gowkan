---
import { SITE_CONFIG } from '../data/site-config';
---

<!-- Footer -->
<footer id="contact" class="py-24 px-6 border-t border-white/5 relative overflow-hidden bg-white/[0.02]">
    <div class="container mx-auto max-w-6xl relative z-10 reveal">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
            <div class="col-span-1 md:col-span-2">
                <div class="text-3xl font-black mb-6 tracking-tighter">{SITE_CONFIG.logo.text}<span class="text-[#6366f1]">{SITE_CONFIG.logo.highlight}</span></div>
                <p class="text-white/40 mb-8 max-w-md leading-relaxed text-lg font-medium">
                    {SITE_CONFIG.description}. Siap mengubah ide Anda menjadi realitas digital? Hubungi kami sekarang.
                </p>
                <div class="flex gap-4">
                    <a href={SITE_CONFIG.social.instagram} class="w-12 h-12 glass-card rounded-2xl flex items-center justify-center hover:bg-[#6366f1] hover:text-white transition-all group border border-white/10 cta-highlight">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                </div>
            </div>
            <div>
                <h4 class="text-lg font-bold mb-6">Navigasi</h4>
                <ul class="space-y-4 text-white/40 font-semibold">
                    {SITE_CONFIG.navigation.map((item) => (
                        <li><a href={item.href} class="hover:text-[#6366f1] transition-colors">{item.label}</a></li>
                    ))}
                </ul>
            </div>
            <div>
                <h4 class="text-lg font-bold mb-6">Hubungi Kami</h4>
                <ul class="space-y-6 text-white/40 font-semibold">
                    <li class="flex items-start gap-4">
                        <div class="w-10 h-10 bg-[#6366f1]/10 rounded-xl flex items-center justify-center text-[#6366f1] shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <span>{SITE_CONFIG.contact.address}, {SITE_CONFIG.contact.location}</span>
                    </li>
                </ul>
            </div>
        </div>
        <div class="pt-8 border-t border-white/5 text-center text-white/20 text-sm font-bold uppercase tracking-widest">
            &copy; {new Date().getFullYear()} {SITE_CONFIG.name}. Seluruh Hak Cipta Dilindungi.
        </div>
    </div>
</footer>
