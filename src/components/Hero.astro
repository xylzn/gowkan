---
import Button from './Button.astro';
import { SITE_CONFIG } from '../data/site-config';
---

<!-- Hero Section -->
<section id="home" class="relative min-h-screen flex items-center justify-center pt-20 px-6 overflow-hidden">
    <div class="container mx-auto max-w-6xl text-center z-10 reveal">
        <div class="inline-block px-4 py-1.5 mb-4 mt-6 rounded-full border border-[#6366f1]/30 bg-[#6366f1]/10 text-[#6366f1] text-[10px] font-bold uppercase tracking-widest animate-pulse">
            🚀 Partner Digital Terpercaya
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-8 leading-[1.1] tracking-tight text-white">
            Bangun Kepercayaan Pelanggan dengan <span class="bg-gradient-to-r from-[#6366f1] via-[#a855f7] to-[#ec4899] bg-clip-text text-transparent">Website Berkelas</span> & Profesional.
        </h1>
        <p class="text-lg md:text-xl text-white/60 mb-10 max-w-2xl mx-auto leading-relaxed font-medium">
            {SITE_CONFIG.description}. Sekali Bayar, Tanpa Biaya Langganan Bulanan.
        </p>
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 mb-4">
            <Button href="#contact-form-section" variant="primary">Konsultasi Gratis</Button>
            <Button href="#gallery" variant="glass">Lihat Website</Button>
        </div>
    </div>
</section>
