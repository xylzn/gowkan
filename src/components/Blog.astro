---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories: Record<string, { color: string, border: string }> = {
    "Tips & Trick": { color: "text-[#6366f1]", border: "hover:border-[#6366f1]/50" },
    "Branding": { color: "text-[#a855f7]", border: "hover:border-[#a855f7]/50" },
    "Optimization": { color: "text-[#ec4899]", border: "hover:border-[#ec4899]/50" }
};
---

<!-- Blog Section -->
<section id="blog" class="py-24 px-6 relative overflow-hidden">
    <div class="container mx-auto max-w-7xl">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8 reveal">
            <div class="max-w-2xl">
                <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-[#6366f1]/30 bg-[#6366f1]/10 text-[#6366f1] text-[10px] font-bold uppercase tracking-widest">
                    Wawasan Terbaru
                </div>
                <h2 class="text-4xl md:text-5xl font-black mb-6 tracking-tight">Edukasi <span class="text-[#6366f1]">Digital</span></h2>
                <p class="text-white/40 font-medium">Tips, trik, dan berita terbaru seputar teknologi web dan strategi branding. <span class="text-[#6366f1]/60 text-xs block mt-2 md:inline md:mt-0 md:ml-2">(Geser untuk melihat lainnya →)</span></p>
            </div>
            <div class="hidden md:flex gap-4">
                <button id="blog-prev" class="arrow-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button id="blog-next" class="arrow-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </button>
            </div>
        </div>

        <div class="carousel-wrapper">
            <div id="blog-carousel" class="carousel-container reveal">
                <div class="carousel-track">
                    {posts.map((post) => {
                        const categoryStyle = categories[post.data.category || ""] || { color: "text-white", border: "hover:border-white/50" };
                        return (
                            <div class="carousel-item">
                                <div class={`glass-card package-card p-8 rounded-[3rem] border border-white/10 ${categoryStyle.border} transition-all group h-full flex flex-col`}>
                                    <div class="aspect-video bg-white/5 rounded-3xl mb-8 overflow-hidden">
                                        <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                                    </div>
                                    <div class="flex-grow px-2">
                                        <span class={`inline-block px-4 py-1.5 rounded-full bg-white/5 ${categoryStyle.color} text-[10px] font-bold uppercase tracking-[0.2em] mb-6`}>{post.data.category}</span>
                                        <h3 class="text-2xl font-black mb-6 leading-tight group-hover:text-[#6366f1] transition-colors tracking-tight">{post.data.title}</h3>
                                        <p class="text-white/40 text-sm leading-relaxed mb-6 font-medium">{post.data.description}</p>
                                    </div>
                                    <a href={`/blog/${post.id}`} class="text-sm font-black flex items-center gap-3 text-white/30 group-hover:text-[#6366f1] transition-all mt-auto px-2">
                                        BACA SELENGKAPNYA 
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>
        </div>
    </div>
</section>
