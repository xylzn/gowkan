---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<MainLayout 
    title="Blog Gowkan - Wawasan Digital & Branding Terupdate"
    description="Temukan tips, trik, dan berita terbaru seputar teknologi web dan strategi branding untuk bisnis Anda."
>
	<Navbar />
	<main class="pt-32 pb-24 px-6 min-h-screen">
        <div class="container mx-auto max-w-6xl reveal">
            <div class="text-center mb-16">
                <div class="inline-block px-4 py-1.5 mb-6 rounded-full border border-[#6366f1]/30 bg-[#6366f1]/10 text-[#6366f1] text-[10px] font-bold uppercase tracking-widest">
                    Blog Gowkan
                </div>
                <h1 class="text-4xl md:text-6xl font-black mb-8 leading-tight text-white tracking-tight">
                    Edukasi <span class="text-[#6366f1]">Digital</span> & Branding
                </h1>
                <p class="text-white/40 text-lg max-w-2xl mx-auto leading-relaxed font-medium">
                    Temukan artikel pilihan kami untuk membantu Anda memahami dunia digital dan memaksimalkan potensi bisnis Anda.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {posts.map((post) => (
                    <div class="glass-card package-card p-8 rounded-[3rem] border border-white/10 hover:border-[#6366f1]/50 transition-all group h-full flex flex-col">
                        <div class="aspect-video bg-white/5 rounded-3xl mb-8 overflow-hidden">
                            <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                        </div>
                        <div class="flex-grow px-2">
                            <span class="inline-block px-4 py-1.5 rounded-full bg-white/5 text-[#6366f1] text-[10px] font-bold uppercase tracking-[0.2em] mb-6">{post.data.category}</span>
                            <h3 class="text-2xl font-black mb-6 leading-tight group-hover:text-[#6366f1] transition-colors tracking-tight">{post.data.title}</h3>
                            <p class="text-white/40 text-sm leading-relaxed mb-6 font-medium">{post.data.description}</p>
                        </div>
                        <a href={`/blog/${post.id}`} class="text-sm font-black flex items-center gap-3 text-white/30 group-hover:text-[#6366f1] transition-all mt-auto px-2">
                            BACA SELENGKAPNYA 
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </a>
                    </div>
                ))}
            </div>
        </div>
	</main>
	<Footer />
</MainLayout>
